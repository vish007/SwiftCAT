{
  "title": "SwiftCAT API Dashboard",
  "panels": [
    {
      "type": "timeseries",
      "title": "HTTP Requests",
      "targets": [{ "expr": "sum(rate(swiftcat_http_requests_total[1m])) by (route)" }]
    },
    {
      "type": "timeseries",
      "title": "P95 Latency",
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(swiftcat_http_request_duration_ms_bucket[5m])) by (le, route))" }]
    }
  ]
}
