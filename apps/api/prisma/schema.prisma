generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkItemState {
  INGESTED
  CLASSIFIED
  SCREENED
  ROUTED
  EXCEPTION
  READY
}

model User {
  id             Int             @id @default(autoincrement())
  username       String          @unique
  passwordHash   String          @map("password_hash")
  refreshToken   String?         @map("refresh_token")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  roleId         Int             @map("role_id")
  role           Role            @relation(fields: [roleId], references: [id])
  messageActions MessageAction[]

  @@map("users")
}

model Role {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  users       User[]
  permissions Permission[]

  @@map("roles")
}

model Permission {
  id          Int    @id @default(autoincrement())
  code        String @unique
  description String
  roleId      Int    @map("role_id")
  role        Role   @relation(fields: [roleId], references: [id])

  @@map("permissions")
}

model Queue {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  createdAt DateTime   @default(now()) @map("created_at")
  workItems WorkItem[]

  @@map("queues")
}

model MessageAction {
  id          Int      @id @default(autoincrement())
  action      String
  entityType  String   @map("entity_type")
  entityId    String   @map("entity_id")
  details     String?
  createdAt   DateTime @default(now()) @map("created_at")
  performedBy Int      @map("performed_by")
  user        User     @relation(fields: [performedBy], references: [id])

  @@map("message_actions")
}

model SwiftMtCode {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  description String
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("swift_mt_codes")
}

model WorkItem {
  id               Int                       @id @default(autoincrement())
  messageType      String                    @map("message_type")
  rawMessage       String                    @map("raw_message")
  domain           String?
  priority         Int                       @default(50)
  rationale        String?
  confidence       Float?
  state            WorkItemState             @default(INGESTED)
  queueId          Int?                      @map("queue_id")
  queue            Queue?                    @relation(fields: [queueId], references: [id])
  createdAt        DateTime                  @default(now()) @map("created_at")
  updatedAt        DateTime                  @updatedAt @map("updated_at")
  screeningResult  ScreeningResult?
  policyDecisions  PolicyDecision[]
  stateTransitions WorkItemStateTransition[]
  agentSteps       AgentStep[]

  @@map("work_items")
}

model AgentStep {
  id          Int      @id @default(autoincrement())
  workItemId  Int      @map("work_item_id")
  workItem    WorkItem @relation(fields: [workItemId], references: [id])
  stepName    String   @map("step_name")
  status      String
  rationale   String?
  createdAt   DateTime @default(now()) @map("created_at")
  policyDecisions PolicyDecision[]

  @@map("agent_steps")
}

model ScreeningResult {
  id          Int      @id @default(autoincrement())
  workItemId  Int      @unique @map("work_item_id")
  workItem    WorkItem @relation(fields: [workItemId], references: [id])
  toolName    String   @map("tool_name")
  hit         Boolean
  score       Float
  riskFactors String   @map("risk_factors")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("screening_results")
}

model PolicyDecision {
  id          Int       @id @default(autoincrement())
  workItemId  Int       @map("work_item_id")
  workItem    WorkItem  @relation(fields: [workItemId], references: [id])
  agentStepId Int?      @map("agent_step_id")
  agentStep   AgentStep? @relation(fields: [agentStepId], references: [id])
  policyName  String    @map("policy_name")
  allow       Boolean
  rationale   String
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("policy_decisions")
}

model WorkItemStateTransition {
  id         Int           @id @default(autoincrement())
  workItemId Int           @map("work_item_id")
  workItem   WorkItem      @relation(fields: [workItemId], references: [id])
  fromState  WorkItemState @map("from_state")
  toState    WorkItemState @map("to_state")
  rationale  String
  createdAt  DateTime      @default(now()) @map("created_at")

  @@map("work_item_state_transitions")
}
