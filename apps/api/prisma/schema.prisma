generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int             @id @default(autoincrement())
  username       String          @unique
  passwordHash   String          @map("password_hash")
  refreshToken   String?         @map("refresh_token")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  roleId         Int             @map("role_id")
  role           Role            @relation(fields: [roleId], references: [id])
  messageActions MessageAction[]

  @@map("users")
}

model Role {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  users       User[]
  permissions Permission[]

  @@map("roles")
}

model Permission {
  id          Int    @id @default(autoincrement())
  code        String @unique
  description String
  roleId      Int    @map("role_id")
  role        Role   @relation(fields: [roleId], references: [id])

  @@map("permissions")
}

model Queue {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  @@map("queues")
}

model MessageAction {
  id          Int      @id @default(autoincrement())
  action      String
  entityType  String   @map("entity_type")
  entityId    String   @map("entity_id")
  details     String?
  createdAt   DateTime @default(now()) @map("created_at")
  performedBy Int      @map("performed_by")
  user        User     @relation(fields: [performedBy], references: [id])

  @@map("message_actions")
}

model SwiftMtCode {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  description String
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("swift_mt_codes")
}

model ToolRegistry {
  toolName         String   @id @map("tool_name")
  domain           String
  inputSchema      Json     @map("input_schema")
  outputSchema     Json     @map("output_schema")
  requiresApproval Boolean  @default(false) @map("requires_approval")
  retryPolicy      Json     @map("retry_policy")
  enabled          Boolean  @default(true)
  invocations      ToolInvocation[]

  @@map("tool_registry")
}

model AgentRun {
  id        Int         @id @default(autoincrement())
  status    String
  createdAt DateTime    @default(now()) @map("created_at")
  steps     AgentStep[]

  @@map("agent_runs")
}

model AgentStep {
  id          Int              @id @default(autoincrement())
  runId       Int              @map("run_id")
  stepType    String           @map("step_type")
  status      String
  createdAt   DateTime         @default(now()) @map("created_at")
  run         AgentRun         @relation(fields: [runId], references: [id])
  invocations ToolInvocation[]

  @@map("agent_steps")
}

model ToolInvocation {
  id             Int        @id @default(autoincrement())
  agentStepId    Int        @map("agent_step_id")
  toolName       String     @map("tool_name")
  idempotencyKey String     @map("idempotency_key")
  request        Json
  response       Json?
  status         String
  attemptCount   Int        @default(1) @map("attempt_count")
  createdAt      DateTime   @default(now()) @map("created_at")
  agentStep      AgentStep  @relation(fields: [agentStepId], references: [id])
  tool           ToolRegistry @relation(fields: [toolName], references: [toolName])

  @@unique([agentStepId, idempotencyKey])
  @@map("tool_invocations")
}
