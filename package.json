{
  "name": "swiftcat-monorepo",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --parallel --filter @swiftcat/api --filter @swiftcat/web dev",
    "test": "pnpm -r --filter ./apps/** --filter ./packages/** test",
    "test:e2e": "pnpm --filter @swiftcat/web test -- src/App.test.tsx",
    "lint": "pnpm -r --filter ./apps/** --filter ./packages/** lint",
    "typecheck": "pnpm -r --filter ./apps/** --filter ./packages/** typecheck",
    "db:migrate": "pnpm --filter @swiftcat/api db:migrate",
    "db:seed": "pnpm --filter @swiftcat/api db:seed"
  }
}
